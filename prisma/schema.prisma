// Sunday League — domain + auth schema
// See plan: /Users/eyakristou/.claude/plans/let-me-explain-the-cuddly-haven.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Auth.js (NextAuth v5)
// =====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================
// Domain
// =====================

enum Position {
  DEF
  MID
  FWD
}

enum GameStatus {
  OPEN
  LOCKED
  BOOKED
  COMPLETED
  CANCELLED
}

enum SignupStatus {
  CONFIRMED
  WAITLIST
  DROPPED_OUT
}

enum TeamLabel {
  A
  B
  C
}

enum PaymentStatus {
  UNPAID
  MARKED_PAID
}

enum PaymentMethod {
  MONZO
  REVOLUT
}

// A match is decided in one of three phases:
//  - REGULAR    : first to 3 goals or 15 minutes.
//  - GOLDEN_GOAL: a tied regular phase goes to a 5-minute golden-goal period.
//  - PENALTIES  : a still-tied golden goal is settled on penalties.
enum MatchPhase {
  REGULAR
  GOLDEN_GOAL
  PENALTIES
}

enum MatchStatus {
  LIVE      // clock is running
  PAUSED    // set up / clock stopped, not yet finished
  COMPLETED // result is final
}

// A member's role within a single group. The creator of a group is its first
// ADMIN; everyone who joins via the key is a MEMBER. This is the per-group
// equivalent of the old global `User.isAdmin` (which is now platform-only).
enum GroupRole {
  ADMIN
  MEMBER
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  passwordHash      String?
  image             String?
  preferredPosition Position?
  paymentMethod     PaymentMethod @default(MONZO)
  paymentHandle     String?
  skillScore        Float     @default(3.0)
  isAdmin           Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  signups           Signup[]
  guestsBrought     Guest[]            @relation("GuestHost")
  teamMemberships   TeamPlayer[]
  ratingsGiven      Rating[]           @relation("RatingsGiven")
  ratingsReceived   Rating[]           @relation("RatingsReceived")
  bookedGames       Game[]             @relation("Booker")
  bibsGames         Game[]             @relation("Bibs")
  footballGames     Game[]             @relation("Football")
  paymentsOwed      PaymentRequest[]   @relation("Debtor")
  paymentsDue       PaymentRequest[]   @relation("Booker")
  pushSubscriptions PushSubscription[]
  goals             Goal[]
  groupMemberships  GroupMember[]
}

// A group is a self-contained club: its own roster (via GroupMember), its own
// weekly games, its own schedule, and its own admin(s). New users join by
// entering the group's `joinKey`. Everything that used to be global — the game
// pool, notifications, booker rotation — is now scoped to one Group.
model Group {
  id                    String   @id @default(cuid())
  name                  String
  joinKey               String   @unique // share token entered at join time
  // --- per-group weekly schedule (replaces the hardcoded Sunday-noon cadence) ---
  kickoffWeekday        Int      @default(0) // 0=Sun .. 6=Sat (in `timezone`)
  kickoffHour           Int      @default(12) // wall-clock hour in `timezone`
  kickoffMinute         Int      @default(0)
  timezone              String   @default("Europe/London")
  // Lock deadline = kickoff − this many hours (42h before Sun-noon ≈ Fri 18:00).
  // Drives when signups close; the admin still locks the lineup manually.
  lockOffsetHours       Int      @default(42)
  // --- defaults stamped onto each game the admin creates ---
  defaultPitchName       String  @default("Ladbroke Grove")
  defaultPitchBookingUrl String  @default("https://hireapitch.com/ladbroke-grove")
  // Free-text note the admin can show all members (e.g. "the game is auto-
  // generated between Mon and Thu"). Displayed on the home page; null = hidden.
  playerNote            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  members GroupMember[]
  games   Game[]
}

// Join row linking a User to a Group, with their role in that group. A user can
// belong to many groups (and switch between them); a group has many members.
// `exemptFromDuties` replaces the old hardcoded EXEMPT_EMAILS set — an organizer
// who never wants to be picked for booker/bibs/football sets this on themselves.
model GroupMember {
  id               String    @id @default(cuid())
  groupId          String
  userId           String
  role             GroupRole @default(MEMBER)
  exemptFromDuties Boolean   @default(false)
  joinedAt         DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId]) // "list my groups" (root picker)
  @@index([groupId]) // "list members of a group" (notification scoping)
}

model Game {
  id              String     @id @default(cuid())
  // NOTE: nullable during the additive migration step; flipped to required after
  // the backfill stamps every existing game (see prisma/backfill-multi-group.ts).
  groupId         String?
  kickoffAt       DateTime
  pitchName       String     @default("Ladbroke Grove")
  pitchBookingUrl String     @default("https://hireapitch.com/ladbroke-grove")
  status          GameStatus @default(OPEN)
  // When an admin flips this on (a week they fear missing the minimum), any
  // confirmed player can add one or more outside "+1" guests to make numbers.
  allowGuests     Boolean    @default(false)
  bookerId        String?
  bibsUserId      String?
  footballUserId  String?
  totalCostPence  Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  group           Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  booker          User?            @relation("Booker", fields: [bookerId], references: [id])
  bibsBringer     User?            @relation("Bibs", fields: [bibsUserId], references: [id])
  footballBringer User?            @relation("Football", fields: [footballUserId], references: [id])
  signups         Signup[]
  guests          Guest[]
  teams           Team[]
  matches         Match[]
  ratings         Rating[]
  paymentRequests PaymentRequest[]

  @@index([kickoffAt])
  @@index([status])
  // Matches the hot access patterns: filter by group + status, range/order by
  // kickoffAt (getCurrentGame, friday-lock, sunday-complete crons).
  @@index([groupId, status, kickoffAt])
  // booker-picking queries filter by group and `bookerId: { in: [...] }`.
  @@index([groupId, bookerId])
}

model Signup {
  id               String       @id @default(cuid())
  gameId           String
  userId           String
  position         Position
  status           SignupStatus @default(CONFIRMED)
  waitlistPosition Int?
  signedUpAt       DateTime     @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId, status])
}

model Team {
  id     String    @id @default(cuid())
  gameId String
  label  TeamLabel

  game    Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  players TeamPlayer[]

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  wonMatches  Match[] @relation("WinnerTeam")
  goals       Goal[]

  @@unique([gameId, label])
}

// A slot in a team. It holds EITHER a member (`userId`) or a guest (`guestId`)
// — exactly one is set (enforced in code). The surrogate `id` replaces the old
// composite (teamId, userId) primary key, which couldn't accommodate a nullable
// userId for guest slots.
model TeamPlayer {
  id      String  @id @default(cuid())
  teamId  String
  userId  String?
  guestId String?

  team  Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guest Guest? @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@unique([teamId, guestId])
  @@index([userId])
  @@index([guestId])
}

// A "+1" — a non-member guest brought along by a confirmed player (the host)
// to help fill out the numbers. Guests have no account, so they can't log in,
// rate, be rated, or be picked for booker/bibs/football (all of which only ever
// read `User`). They DO count toward the roster + teams, and their share of the
// pitch cost is billed to their host. Displayed everywhere as "<host> +1".
model Guest {
  id         String   @id @default(cuid())
  gameId     String
  hostUserId String
  createdAt  DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  host User @relation("GuestHost", fields: [hostUserId], references: [id], onDelete: Cascade)

  teamMemberships TeamPlayer[]

  @@index([gameId])
  @@index([hostUserId])
}

// IMPORTANT: raterId is NEVER shown to regular members — it exists server-side
// to enforce one-rating-per-pair-per-game. The single exception is the
// owner-gated /ratings/audit page (see src/lib/ratings-audit.ts).
model Rating {
  id        String   @id @default(cuid())
  gameId    String
  raterId   String
  rateeId   String
  score     Int
  createdAt DateTime @default(now())

  game  Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  rater User @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  ratee User @relation("RatingsReceived", fields: [rateeId], references: [id], onDelete: Cascade)

  @@unique([gameId, raterId, rateeId])
  @@index([rateeId])
}

model PaymentRequest {
  id          String        @id @default(cuid())
  gameId      String
  debtorId    String
  bookerId    String
  amountPence Int
  paymentLink String
  paidStatus  PaymentStatus @default(UNPAID)
  createdAt   DateTime      @default(now())

  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  debtor User @relation("Debtor", fields: [debtorId], references: [id], onDelete: Cascade)
  booker User @relation("Booker", fields: [bookerId], references: [id], onDelete: Cascade)

  @@unique([gameId, debtorId])
  @@index([debtorId])
}

// One-time email sign-in codes. One active code per email (upserted).
// `attempts` counts failed verifications so we can lock a code after a few
// wrong guesses (brute-force protection — a 6-digit code has only 10^6 space).
// `createdAt` doubles as the last-issued timestamp (reset on resend) so we can
// throttle how often a fresh code can be requested for the same email.
model LoginCode {
  id        String   @id @default(cuid())
  email     String   @unique
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

// Fixed-window rate-limit counters, keyed by "action:identifier" (e.g.
// "pwreset:email:foo@bar.com" or "signin:ip:1.2.3.4"). `expiresAt` is the end
// of the current window; once it passes, the next hit resets the count. Used to
// throttle auth emails (anti email-bomb) and login attempts (anti brute-force).
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}

// A single match played within a Sunday (Game). A Game can have many — we play
// several back-to-back until we're tired. Two of the (up to 3) teams play each
// match. The clock is a server-anchored stopwatch for the CURRENT phase: while
// running, `periodStartedAt` holds the instant the clock last started and
// `accumulatedMs` holds time banked before that; while paused, `periodStartedAt`
// is null and `accumulatedMs` holds the full elapsed time. Every client derives
// the same remaining time from these two fields, so the timer is synced.
model Match {
  id              String      @id @default(cuid())
  gameId          String
  order           Int // 1, 2, 3… within the day
  homeTeamId      String
  awayTeamId      String
  status          MatchStatus @default(LIVE)
  phase           MatchPhase  @default(REGULAR)
  periodStartedAt DateTime? // when the clock last started (null = not running)
  accumulatedMs   Int         @default(0) // elapsed ms banked in the current phase
  homePenalties   Int         @default(0)
  awayPenalties   Int         @default(0)
  winnerTeamId    String? // set on completion (rules always force a winner)
  startedAt       DateTime? // first kickoff, for display
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  game       Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  homeTeam   Team  @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam   Team  @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  winnerTeam Team? @relation("WinnerTeam", fields: [winnerTeamId], references: [id])
  goals      Goal[]

  @@index([gameId, order])
}

// One goal in a match. `teamId` is the team it counts FOR (so an own goal is
// recorded against the beneficiary team with `isOwnGoal = true`). `scorerId` is
// optional — you can bump the score without naming who scored. `clockMs` is the
// match-clock position when it went in, for the goal timeline.
model Goal {
  id        String     @id @default(cuid())
  matchId   String
  teamId    String
  scorerId  String?
  phase     MatchPhase @default(REGULAR) // REGULAR or GOLDEN_GOAL
  isOwnGoal Boolean    @default(false)
  clockMs   Int        @default(0)
  createdAt DateTime   @default(now())

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team   Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  scorer User? @relation(fields: [scorerId], references: [id], onDelete: SetNull)

  @@index([matchId])
  @@index([scorerId])
}

// Web Push subscription. One row per device, so a user may have several.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
